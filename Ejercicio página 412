import tkinter as tk
from tkinter import messagebox
import math
class CalculosNumericos:
    @staticmethod
    def calcular_logaritmo(valor):
        if valor <= 0:
            raise ValueError("El valor debe ser un número positivo para el logaritmo.")
        return math.log(valor)

    @staticmethod
    def calcular_raiz(valor):
        if valor < 0:
            raise ValueError("El valor debe ser un número positivo para la raíz cuadrada.")
        return math.sqrt(valor)

#Interfaz Gráfica
class VentanaCalculos(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("Catchs Múltiples")
        self.geometry("350x450")
        self.resizable(False, False)
        self.inicio()

    def inicio(self):
        #entrada de datos
        tk.Label(self, text="Ingrese un valor:").place(x=20, y=20)
        self.campo_valor = tk.Entry(self)
        self.campo_valor.place(x=130, y=20, width=150)

        #mostrar el resultado
        tk.Label(self, text="Resultado:").place(x=20, y=60)
        self.campo_resultado = tk.Entry(self, state="readonly")
        self.campo_resultado.place(x=130, y=60, width=150)

        #Botones
        btn_log = tk.Button(self, text="Calcular Logaritmo", command=self.ejecutar_log, width=18)
        btn_log.place(x=20, y=110)

        btn_raiz = tk.Button(self, text="Calcular Raíz", command=self.ejecutar_raiz, width=18)
        btn_raiz.place(x=175, y=110)

        btn_limpiar = tk.Button(self, text="Limpiar Campos", command=self.limpiar, width=40)
        btn_limpiar.place(x=20, y=150)

        #ver el flujo de excepciones
        tk.Label(self, text="Log de Ejecución:", font=("Arial", 9, "italic")).place(x=20, y=200)
        self.consola = tk.Text(self, height=10, width=38, bg="black", fg="#00FF00")
        self.consola.place(x=20, y=220)
        self.consola.config(state=tk.DISABLED)

    def escribir_log(self, mensaje):
        self.consola.config(state=tk.NORMAL)
        self.consola.insert(tk.END, mensaje + "\n")
        self.consola.see(tk.END)
        self.consola.config(state=tk.DISABLED)

    def ejecutar_log(self):
        self.escribir_log(">>> Intentando calcular Logaritmo...")
        self.procesar_calculo(CalculosNumericos.calcular_logaritmo)

    def ejecutar_raiz(self):
        self.escribir_log(">>> Intentando calcular Raíz Cuadrada...")
        self.procesar_calculo(CalculosNumericos.calcular_raiz)

    def procesar_calculo(self, funcion_matematica):
        """
        Gestiona múltiples excepciones en un solo bloque, 
        tal como pide el ejercicio 6.6 de la fuente.
        """
        try:
            #Captura de entrada
            valor_str = self.campo_valor.get()
            if not valor_str: raise ValueError("El campo está vacío.")
            
            numero = float(valor_str)

            #lógica
            resultado = funcion_matematica(numero)
            
            #Mostrar éxito
            self.campo_resultado.config(state="normal")
            self.campo_resultado.delete(0, tk.END)
            self.campo_resultado.insert(0, f"{resultado:.4f}")
            self.campo_resultado.config(state="readonly")
            self.escribir_log("OPERACIÓN EXITOSA.")

        except ValueError as e:
            #Captura errores
            self.escribir_log(f"CAPTURA: {e}")
            messagebox.showerror("Error de Cálculo", str(e))
        
        except Exception as e:
            #Captura general
            self.escribir_log(f"ERROR GENERAL: {e}")
        
        finally:
            #El flujo siempre pasa por acá
            self.escribir_log("Ciclo de cálculo finalizado.")
            self.escribir_log("------------------------------")

    def limpiar(self):
        self.campo_valor.delete(0, tk.END)
        self.campo_resultado.config(state="normal")
        self.campo_resultado.delete(0, tk.END)
        self.campo_resultado.config(state="readonly")
        self.consola.config(state=tk.NORMAL)
        self.consola.delete('1.0', tk.END)
        self.consola.config(state=tk.DISABLED)


app = VentanaCalculos()
app.mainloop()
